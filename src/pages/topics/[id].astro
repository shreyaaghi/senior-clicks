---
import { supabase } from '../../lib/supabase';
import Checklist from '../../components/Checklist';
import Glossary from '../../components/Glossary.astro';
import PracticeScenario from '../../components/PracticeScenario';
import ZoomJoinCall from '../../components/simulations/ZoomJoinCall';

const { id } = Astro.params;

const { data: topic, error: topicError } = await supabase
  .from('topics')
  .select(`
    id,
    title,
    description,
    modules (
      id,
      type,
      title,
      order_index
    )
  `)
  .eq('id', id)
  .order('order_index')
  .single();

if (topicError) {
  console.error('error loading topic:', topicError);
}

const checklistModule = topic?.modules?.find((m) => m.type === 'checklist');

let checklistItems = [];
if (checklistModule) {
  const { data, error: itemsError } = await supabase
    .from('checklist_items')
    .select('*')
    .eq('module_id', checklistModule.id)
    .order('order_index', { ascending: true });

  if (itemsError) {
    console.error('Error loading checklist items:', itemsError);
  } else {
    checklistItems = data;
  }
}

const glossaryModule = topic?.modules?.find((m) => m.type === 'glossary');

let glossaryItems = [];
if (glossaryModule) {
  const { data, error: itemsError } = await supabase
    .from('glossary_items')
    .select('*')
    .eq('module_id', glossaryModule.id)
    .order('order_index', { ascending: true });

  if (itemsError) {
    console.error('error loading glossary items:', itemsError);
  } else {
    glossaryItems = data;
  }
}

const practiceScenarioModule = topic?.modules?.find((m) => m.type === 'quiz');

let questions = [];
if (practiceScenarioModule) {
  const { data, error: itemsError } = await supabase
    .from('quiz_questions')
    .select('*, quiz_options(*)')
    .eq('module_id', practiceScenarioModule.id)
    .order('order_index', { ascending: true });

  if (itemsError) {
    console.error('error loading quiz items:', itemsError);
  } else {
    questions = data;
  }
}

const simulationModule = topic?.modules?.find((m) => m.type === 'simulation');

---

<h1>{topic?.title}</h1>
<p>{topic?.description}</p>
<li>
  <a href={`/`}>Home</a>
</li>

{checklistModule && (
  <div>
    <h2>{checklistModule.title}</h2>
    <Checklist items={checklistItems} client:load />
  </div>
)}

{glossaryModule && (
  <div>
    <h2>{glossaryModule.title}</h2>
    <Glossary items={glossaryItems} />
  </div>
)}

{practiceScenarioModule && (
  <div>
    <h2>{practiceScenarioModule.title}</h2>
    <PracticeScenario questions={questions} client:load />
  </div>
)}

{simulationModule && (
  <div>
    <h2>{simulationModule.title}</h2>
    <ZoomJoinCall client:load></ZoomJoinCall>
  </div>
)}